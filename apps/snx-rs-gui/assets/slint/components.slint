import { Palette } from "std-widgets.slint";

export component IconButton inherits Rectangle {
    in property <bool> enabled: true;
    in property <string> tooltip;
    callback clicked();

    width: 24px;
    height: 24px;
    border-radius: 4px;
    background: !root.enabled ? transparent
              : ta.pressed ? Palette.control-background.darker(0.2)
              : ta.has-hover ? Palette.control-background.darker(0.1)
              : transparent;

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: root.enabled ? MouseCursor.pointer : MouseCursor.default;
        clicked => { root.clicked(); }
    }

    @children

    if root.tooltip != "" && ta.has-hover: Rectangle {
        x: -self.width - 6px;
        y: (parent.height - self.height) / 2;
        width: tooltip-text.preferred-width + 12px;
        height: tooltip-text.preferred-height + 6px;
        background: Palette.foreground.transparentize(0.1);
        border-radius: 4px;

        tooltip-text := Text {
            text: root.tooltip;
            color: Palette.background;
            font-size: 12px;
        }
    }
}

export component PlusIcon inherits Path {
    in property <color> tint: #2e7d32;
    stroke: root.tint;
    stroke-width: 2px;
    viewbox-x: 0;
    viewbox-y: 0;
    viewbox-width: 10;
    viewbox-height: 10;
    width: 14px;
    height: 14px;
    MoveTo { x: 5; y: 1; }
    LineTo { x: 5; y: 9; }
    MoveTo { x: 1; y: 5; }
    LineTo { x: 9; y: 5; }
}

export component PencilIcon inherits Path {
    in property <color> tint: Palette.foreground;
    stroke: root.tint;
    stroke-width: 1.2px;
    fill: root.tint.transparentize(0.85);
    viewbox-x: 0;
    viewbox-y: 0;
    viewbox-width: 10;
    viewbox-height: 10;
    width: 14px;
    height: 14px;
    MoveTo { x: 1.5; y: 8.5; }
    LineTo { x: 2.5; y: 6.5; }
    LineTo { x: 6.5; y: 2.5; }
    LineTo { x: 8.5; y: 4.5; }
    LineTo { x: 4.5; y: 8.5; }
    LineTo { x: 2.5; y: 9.5; }
    LineTo { x: 1.5; y: 8.5; }
}

