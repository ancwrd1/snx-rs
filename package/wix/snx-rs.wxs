<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
    Name="SNX-RS VPN Client"
    Manufacturer="Dmitry Pankratov"
    Version="$(var.Version)"
    UpgradeCode="b9c8f7a4-2a14-4abc-9def-0123456789ab"
    Scope="perMachine"
    InstallerVersion="500">

    <SummaryInformation Description="SNX-RS VPN Client" />

    <!-- Schedule="afterInstallInitialize" removes the old product (including
         its UninstallService CA, which stops + deletes the service) before
         any new file write, so in-use file handles on snx-rs.exe / wintun.dll
         are released first. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed."
                  Schedule="afterInstallInitialize"
                  AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" />

    <!-- Suppress MSI's RestartManager / FilesInUse dialog. It fires during
         InstallValidate, before any deferred CA can run, so the user sees a
         "these apps are running" prompt that can't actually stop our
         service-hosted exe. Our StopServiceForce + KillGui CAs (scheduled
         Before InstallFiles) handle the lock release instead. -->
    <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />
    <Property Id="MSIDISABLERMRESTART" Value="1" />
    <Property Id="RESTART_MANAGER_DISABLED" Value="1" />

    <ui:WixUI Id="WixUI_InstallDir" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_ErrorProgressText" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.LicenseRtf)" />

    <!-- Pre-accept the license so the LicenseAgreementDlg's "I accept" checkbox
         is not a gate on Next. AGPL doesn't require click-through acceptance. -->
    <Property Id="LicenseAccepted" Value="1" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="snx-rs" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="SNX-RS VPN Client" />
    </StandardDirectory>

    <Feature Id="Main" Title="SNX-RS VPN Client" Level="1">
      <ComponentGroupRef Id="MainFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="ToastAppId" />
    </Feature>

    <!-- All command CAs run via util:WixQuietExec64 (Wix4UtilCA_X64) so the
         child process is launched with a hidden window - sc.exe / net.exe /
         taskkill.exe are console-subsystem and would otherwise flash a
         console. Deferred CAs read the command line from CustomActionData;
         we set that via a paired immediate "setter" CA whose Property
         attribute matches the deferred CA Id. Immediate CAs read it from
         the WixQuietExec64CmdLine property, set with SetProperty just
         before each invocation. -->

    <!-- InstallService: "<snx-rs.exe> -m install" (deferred, elevated) -->
    <CustomAction Id="SetInstallServiceCmd"
                  Property="InstallService"
                  Value="&quot;[#SnxRsExeFile]&quot; -m install" />
    <CustomAction Id="InstallService"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- UninstallService: "<snx-rs.exe> -m uninstall" (deferred, elevated) -->
    <CustomAction Id="SetUninstallServiceCmd"
                  Property="UninstallService"
                  Value="&quot;[#SnxRsExeFile]&quot; -m uninstall" />
    <CustomAction Id="UninstallService"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- StartService: sc.exe start snx-rs (deferred, elevated). sc.exe returns
         immediately without waiting for the service to reach RUNNING, which
         is what we want - net.exe would block until startup completes. -->
    <CustomAction Id="SetStartServiceCmd"
                  Property="StartService"
                  Value="&quot;[System64Folder]sc.exe&quot; start snx-rs" />
    <CustomAction Id="StartService"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Force-stop the service and kill the GUI (running in the user session)
         so the exes are no longer file-locked. Best-effort: non-zero exit
         when the target isn't running is fine. Immediate (not deferred): we
         must run BEFORE RemoveExistingProducts so the old MSI's uninstall
         can delete unlocked files, and deferred CAs can't be scheduled
         before MajorUpgrade's afterInstallInitialize REP slot. The MSI
         already runs elevated, so net.exe / taskkill have the rights they
         need. -->
    <SetProperty Id="WixQuietExec64CmdLine"
                 Value="&quot;[System64Folder]net.exe&quot; stop snx-rs /y"
                 Before="StopServiceForce"
                 Sequence="execute" />
    <CustomAction Id="StopServiceForce"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X64"
                  Execute="immediate"
                  Return="ignore" />

    <SetProperty Id="WixQuietExec64CmdLine"
                 Value="&quot;[System64Folder]taskkill.exe&quot; /F /IM snx-rs-gui.exe /T"
                 Before="KillGui"
                 Sequence="execute" />
    <CustomAction Id="KillGui"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X64"
                  Execute="immediate"
                  Return="ignore" />

    <!-- Delete any leftover snx-rs service before (re)creating it. Covers the
         case where the old product's UninstallService didn't run (e.g.
         upgrading from a pre-CA MSI, or the old CA failed silently). sc.exe
         delete on a missing service returns 1060 - Return="ignore". -->
    <CustomAction Id="SetDeleteServiceForceCmd"
                  Property="DeleteServiceForce"
                  Value="&quot;[System64Folder]sc.exe&quot; delete snx-rs" />
    <CustomAction Id="DeleteServiceForce"
                  DllEntry="WixQuietExec64"
                  BinaryRef="Wix4UtilCA_X64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <!-- Stop the OLD product's processes BEFORE RemoveExistingProducts kicks
           off the old MSI's uninstall - otherwise the old uninstall hits
           locked snx-rs.exe / snx-rs-gui.exe and RemoveFiles errors out with
           2911. Unconditional so it also runs on plain uninstall/repair. -->
      <Custom Action="StopServiceForce" Before="RemoveExistingProducts" />
      <Custom Action="KillGui" After="StopServiceForce" />
      <Custom Action="SetUninstallServiceCmd" Before="UninstallService" Condition="Installed AND (REMOVE=&quot;ALL&quot; OR UPGRADINGPRODUCTCODE)" />
      <Custom Action="UninstallService" Before="RemoveFiles" Condition="Installed AND (REMOVE=&quot;ALL&quot; OR UPGRADINGPRODUCTCODE)" />
      <!-- UPGRADINGPRODUCTCODE is set on the OLD product during its
           upgrade-triggered uninstall; we must NOT (re)install the service
           from that session. `NOT Installed` is true for the NEW product's
           install/upgrade session, which is when we actually want to run. -->
      <Custom Action="SetDeleteServiceForceCmd" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="DeleteServiceForce" After="SetDeleteServiceForceCmd" Condition="NOT Installed" />
      <Custom Action="SetInstallServiceCmd" After="DeleteServiceForce" Condition="NOT Installed" />
      <Custom Action="InstallService" After="SetInstallServiceCmd" Condition="NOT Installed" />
      <Custom Action="SetStartServiceCmd" After="InstallService" Condition="NOT Installed" />
      <Custom Action="StartService" After="SetStartServiceCmd" Condition="NOT Installed" />
    </InstallExecuteSequence>
  </Package>

  <Fragment>
    <ComponentGroup Id="MainFiles" Directory="INSTALLFOLDER">
      <Component Id="SnxRsExe" Bitness="always64">
        <File Id="SnxRsExeFile" Source="$(var.StageDir)\snx-rs.exe" KeyPath="yes" />
      </Component>
      <Component Id="SnxctlExe" Bitness="always64">
        <File Source="$(var.StageDir)\snxctl.exe" KeyPath="yes" />
      </Component>
      <Component Id="SnxRsGuiExe" Bitness="always64">
        <File Source="$(var.StageDir)\snx-rs-gui.exe" KeyPath="yes" />
      </Component>
      <Component Id="WintunDll" Bitness="always64">
        <File Source="$(var.StageDir)\wintun.dll" KeyPath="yes" />
      </Component>
      <Component Id="SnxRsPng" Bitness="always64">
        <File Id="SnxRsPng" Source="$(var.StageDir)\snx-rs.png" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="b9c8f7a4-2a14-4abc-9def-0123456789ac">
      <Shortcut Id="GuiShortcut"
                Name="SNX-RS VPN Client"
                Description="SNX-RS VPN Client"
                Target="[INSTALLFOLDER]snx-rs-gui.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenu" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\snx-rs" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="ToastAppId" Directory="INSTALLFOLDER" Guid="b9c8f7a4-2a14-4abc-9def-0123456789ad" Bitness="always64">
      <RegistryKey Root="HKCR" Key="AppUserModelId\com.github.snx-rs">
        <RegistryValue Type="string" Name="DisplayName" Value="SNX-RS VPN Client" />
        <RegistryValue Type="string" Name="IconUri" Value="[INSTALLFOLDER]snx-rs.png" />
      </RegistryKey>
    </Component>
  </Fragment>
</Wix>
